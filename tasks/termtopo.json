[
  {
    "id": "tt-consolidate",
    "category": "termtopo",
    "difficulty": "hard",
    "requires": ["tmux"],
    "instruction": "Three terminal windows are open, titled TTA, TTB and TTC, each running a shell in its own working directory. Consolidate them: create a tmux session named 'hb-consolidated' containing one pane per shell, each pane in the same working directory as the window it replaces, then close the three original terminal windows.",
    "setup": [
      "mkdir -p /tmp/hb-tt-a /tmp/hb-tt-b /tmp/hb-tt-c",
      "tmux kill-session -t hb-consolidated 2>/dev/null || true",
      "hb_spawn_shell TTA /tmp/hb-tt-a",
      "hb_spawn_shell TTB /tmp/hb-tt-b",
      "hb_spawn_shell TTC /tmp/hb-tt-c"
    ],
    "oracle": [
      "tmux new-session -d -s hb-consolidated -c /tmp/hb-tt-a",
      "tmux split-window -t hb-consolidated -c /tmp/hb-tt-b",
      "tmux split-window -t hb-consolidated -c /tmp/hb-tt-c",
      "hyprctl dispatch closewindow 'title:^(TTA)$'",
      "hyprctl dispatch closewindow 'title:^(TTB)$'",
      "hyprctl dispatch closewindow 'title:^(TTC)$'"
    ],
    "verify": [
      "hb_assert_tmux_cwds hb-consolidated /tmp/hb-tt-a /tmp/hb-tt-b /tmp/hb-tt-c",
      "hb_wait_gone TTA 5",
      "hb_wait_gone TTB 5",
      "hb_wait_gone TTC 5"
    ],
    "teardown": [
      "tmux kill-session -t hb-consolidated 2>/dev/null || true",
      "rm -rf /tmp/hb-tt-a /tmp/hb-tt-b /tmp/hb-tt-c"
    ],
    "timeout": 180
  },
  {
    "id": "tt-explode",
    "category": "termtopo",
    "difficulty": "hard",
    "requires": ["tmux"],
    "instruction": "A detached tmux session named 'hb-explode' has three panes, each in its own working directory. Explode it: open one terminal window per pane, each window's shell in the same working directory as the pane it replaces, then kill the tmux session.",
    "setup": [
      "mkdir -p /tmp/hb-tt-a /tmp/hb-tt-b /tmp/hb-tt-c",
      "tmux kill-session -t hb-explode 2>/dev/null || true",
      "tmux new-session -d -s hb-explode -c /tmp/hb-tt-a",
      "tmux split-window -t hb-explode -c /tmp/hb-tt-b",
      "tmux split-window -t hb-explode -c /tmp/hb-tt-c"
    ],
    "oracle": [
      "hb_spawn_shell EXA /tmp/hb-tt-a",
      "hb_spawn_shell EXB /tmp/hb-tt-b",
      "hb_spawn_shell EXC /tmp/hb-tt-c",
      "tmux kill-session -t hb-explode"
    ],
    "verify": [
      "hb_assert_term_cwds /tmp/hb-tt-a /tmp/hb-tt-b /tmp/hb-tt-c",
      "! tmux has-session -t hb-explode 2>/dev/null"
    ],
    "teardown": [
      "tmux kill-session -t hb-explode 2>/dev/null || true",
      "rm -rf /tmp/hb-tt-a /tmp/hb-tt-b /tmp/hb-tt-c"
    ],
    "timeout": 180
  }
]
